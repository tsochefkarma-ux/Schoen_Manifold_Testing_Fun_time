from sage.all import *
from itertools import combinations

# Restart-safe recovery of cell 25 from the completed cell-24 certificate.
# No cells 13--24 are required.  The embedded affine map is copied from
# the 1280-bit, 70-point cell-24 output and is therefore numerical data,
# not a replacement for the later exact symbolic certificate.

print("="*78, flush=True)
print("RESTART-SAFE CONNECTION-CONSTRAINT / UNIVERSAL-DRIFT REDUCTION", flush=True)
print("Loading the certified affine map from completed cell 24", flush=True)
print("="*78, flush=True)
print(flush=True)
BITS = 1280
RF = RealField(BITS)
pi = RF.pi()
L = 2*pi
gamma_quarter = RF(gamma(QQ(1)/4).n(prec=BITS))
E4i = 3*gamma_quarter**8/(2*pi)**6
Y = L**2*E4i
alpha0 = (Y + 12)/72
C0 = 144*pi**3*exp(-pi/3)/gamma_quarter**4

CONNECTION_NAMES_25R = ['alpha_const', 'beta_const', 'alpha_U_-3', 'beta_U_-3', 'alpha_U_-2', 'beta_U_-2', 'alpha_U_-1', 'alpha_U_1', 'alpha_U_2']
P0_25R = vector(RF, [
    RF('-0.'),
    RF('-0.'),
    RF('0.'),
    RF('0.'),
    RF('0.'),
    RF('0.'),
    RF('0.'),
    RF('0.'),
    RF('-0.'),
])
SLOPES_25R = [
    vector(RF, [
        RF('0.'),
        RF('-0.'),
        RF('0.'),
        RF('0.'),
        RF('0.'),
        RF('0.'),
        RF('-0.'),
        RF('-4.-383'),
        RF('7.-385'),
    ]),
    vector(RF, [
        RF('-2.'),
        RF('2.'),
        RF('0.'),
        RF('0.'),
        RF('-7.'),
        RF('-8.'),
        RF('4.'),
        RF('1.-382'),
        RF('-2.-384'),
    ]),
    vector(RF, [
        RF('-1.'),
        RF('-2.'),
        RF('0.'),
        RF('0.'),
        RF('0.'),
        RF('0.'),
        RF('-0.'),
        RF('6.-382'),
        RF('-8.-384'),
    ]),
]

def max_abs_25R(values):
    values = list(values)
    return max([abs(RF(v)) for v in values] + [RF(0)])



def row_entries_25R(M, i):
    """Return row i as scalar entries across Sage versions."""
    return [M[i, j] for j in range(M.ncols())]


def numerical_rref_25R(rows, tol):
    A = [[RF(value) for value in row] for row in rows]
    m = len(A)
    n = len(A[0]) if m else 0
    pivot_columns = []
    r = 0
    for c in range(n):
        pivot = max(range(r, m), key=lambda i: abs(A[i][c]), default=None)
        if pivot is None or abs(A[pivot][c]) <= tol:
            continue
        A[r], A[pivot] = A[pivot], A[r]
        qv = A[r][c]
        A[r] = [value/qv for value in A[r]]
        for i in range(m):
            if i == r:
                continue
            factor = A[i][c]
            if abs(factor) > tol:
                A[i] = [A[i][j] - factor*A[r][j] for j in range(n)]
        pivot_columns.append(c)
        r += 1
        if r == m:
            break
    return A, pivot_columns

TOL = RF(10)**(-80)
RANK_TOL = RF(10)**(-70)
DISPLAY_TOL = RF(10)**(-55)
NAMES = list(CONNECTION_NAMES_25R)
P0V = vector(RF, P0_25R)
S = matrix(RF, len(NAMES), 3, [
    SLOPES_25R[column][row]
    for row in range(len(NAMES))
    for column in range(3)
])

_, master_indices = numerical_rref_25R([list(row) for row in S.transpose().rows()], RANK_TOL)
if len(master_indices) != 3:
    raise ArithmeticError("Expected three master rows; found {}".format(master_indices))
master_names = [NAMES[i] for i in master_indices]
print("Working real precision: {} bits".format(RF.precision()), flush=True)
print("Embedded cell-24 radial validation: 70 points", flush=True)
print("Geometry-slope rank: 3", flush=True)
print("Canonical master coefficients: {}".format(master_names), flush=True)
print(flush=True)

# Universal drift recognition.
i1 = NAMES.index("alpha_U_1")
i2 = NAMES.index("alpha_U_2")
A1_obs = P0V[i1]
A2_obs = P0V[i2]
A1_pred = alpha0*C0**2/(81*L)
A2_pred = -alpha0*C0**2/243
A1_error = abs(A1_obs-A1_pred)
A2_error = abs(A2_obs-A2_pred)
ratio_error = abs(A1_obs/A2_obs + 3/L)
univ_slope_error = max_abs_25R(row_entries_25R(S, i1) + row_entries_25R(S, i2))
print("Universal positive-U drift recognition:", flush=True)
print("  observed alpha_U_1 = {}".format(A1_obs), flush=True)
print("  predicted alpha0*C0^2/(81*L) = {}".format(A1_pred), flush=True)
print("  absolute error = {}".format(A1_error), flush=True)
print("  observed alpha_U_2 = {}".format(A2_obs), flush=True)
print("  predicted -alpha0*C0^2/243 = {}".format(A2_pred), flush=True)
print("  absolute error = {}".format(A2_error), flush=True)
print("  A1/A2 = -3/L error = {}".format(ratio_error), flush=True)
print("  recognized at 1e-80? {}".format(A1_error<TOL and A2_error<TOL and ratio_error<TOL), flush=True)
print("  maximum geometry slope = {}".format(univ_slope_error), flush=True)
print("  geometry-independent at 1e-80? {}".format(univ_slope_error<TOL), flush=True)
print("  alpha_univ(U) = (alpha0*C0^2/243)*U*(3/L-U)", flush=True)
print("  beta_univ(U) = 0", flush=True)
print(flush=True)

# Six affine constraints.
M = matrix(RF, [row_entries_25R(S, i) for i in master_indices])
if abs(M.det()) <= RANK_TOL:
    raise ArithmeticError("Master slope matrix is singular")
constraints = []
max_slope_error = RF(0)
for i,name in enumerate(NAMES):
    if i in master_indices:
        continue
    target = vector(RF, row_entries_25R(S, i))
    lambdas = M.transpose().solve_right(target)
    const = P0V[i] - sum(lambdas[j]*P0V[master_indices[j]] for j in range(3))
    rebuilt = sum((lambdas[j]*vector(RF, row_entries_25R(S, master_indices[j])) for j in range(3)), vector(RF,3,[0,0,0]))
    err = max_abs_25R(list(target-rebuilt))
    max_slope_error = max(max_slope_error,err)
    constraints.append((name,const,list(lambdas),err))
print("Six canonical affine connection constraints:", flush=True)
for name,const,lambdas,err in constraints:
    terms = ["({})*{}".format(lam,mn) for lam,mn in zip(lambdas,master_names) if abs(lam)>DISPLAY_TOL]
    rhs = " + ".join(terms) if terms else "0"
    if abs(const)>DISPLAY_TOL:
        rhs += " + ({})".format(const)
    print("  {} = {}".format(name,rhs), flush=True)
    print("    slope reconstruction error = {}".format(err), flush=True)
print("  maximum constraint slope error = {}".format(max_slope_error), flush=True)
print(flush=True)

# Sparse proportional relations.
pairs=[]
for i,j in combinations(range(len(NAMES)),2):
    ri=vector(RF, row_entries_25R(S, i)); rj=vector(RF, row_entries_25R(S, j))
    if max_abs_25R(ri)<TOL or max_abs_25R(rj)<TOL:
        continue
    pivot=max(range(3),key=lambda k:abs(rj[k]))
    rho=ri[pivot]/rj[pivot]
    err=max_abs_25R(list(ri-rho*rj))
    if err<TOL:
        const=P0V[i]-rho*P0V[j]
        pairs.append((NAMES[i],NAMES[j],rho,const,err))
print("Sparse two-coefficient relations valid for every geometry:", flush=True)
if pairs:
    for left,right,rho,const,err in pairs:
        print("  {} = ({})*{} + ({})".format(left,rho,right,const), flush=True)
        print("    slope error = {}".format(err), flush=True)
else:
    print("  none", flush=True)
print(flush=True)
print("Polar-channel alignment diagnostics:", flush=True)
for an,bn in [("alpha_U_-3","beta_U_-3"),("alpha_U_-2","beta_U_-2")]:
    ia=NAMES.index(an); ib=NAMES.index(bn)
    ra=vector(RF, row_entries_25R(S, ia)); rb=vector(RF, row_entries_25R(S, ib))
    pivot=max(range(3),key=lambda k:abs(ra[k]))
    rho=rb[pivot]/ra[pivot]
    serr=max_abs_25R(list(rb-rho*ra))
    ierr=abs(P0V[ib]-rho*P0V[ia])
    print("  {}/{} ratio = {}".format(bn,an,rho), flush=True)
    print("    slope proportionality error = {}".format(serr), flush=True)
    print("    intercept proportionality error = {}".format(ierr), flush=True)
    print("    homogeneous alignment at 1e-80? {}".format(serr<TOL and ierr<TOL), flush=True)

# Optional live validation when the old namespace is available.
live_names=["TEST_GEOMETRIES_24","solve_connection_24","affine_predict_24","allpoint_residual_24"]
live=all(name in globals() for name in live_names)
max_direct=RF(0); max_affine=RF(0); max_closure=RF(0)
if live:
    def cres(v):
        v=vector(RF,v); out=[]
        for name,const,lambdas,err in constraints:
            i=NAMES.index(name)
            pred=const+sum(lambdas[j]*v[master_indices[j]] for j in range(3))
            out.append(v[i]-pred)
        return out
    for label,geom in TEST_GEOMETRIES_24:
        direct=solve_connection_24(geom)
        affine=affine_predict_24(P0_24,SLOPES_24,geom)
        max_direct=max(max_direct,max_abs_25R(cres(direct)))
        max_affine=max(max_affine,max_abs_25R(cres(affine)))
        max_closure=max(max_closure,allpoint_residual_24(geom,affine))
else:
    # Certified bounds inherited from the completed 70-point cell-24 run.
    max_closure=RF("3.-378")

# Save a small checkpoint for later restart-safe cells.
checkpoint={
    "names":NAMES,"p0":list(P0V),"slopes":[list(v) for v in SLOPES_25R],
    "master_indices":master_indices,"master_names":master_names,
    "constraints":constraints,"alpha0":alpha0,"C0":C0,"L":L,
    "A1_pred":A1_pred,"A2_pred":A2_pred
}
save(checkpoint,"connection_affine_checkpoint.sobj")

print(flush=True)
print("="*78, flush=True)
print("RESTART-SAFE CONNECTION-CONSTRAINT SUMMARY", flush=True)
print("  master coefficients: {}".format(master_names), flush=True)
print("  affine constraints: {}".format(len(constraints)), flush=True)
print("  universal drift recognized at 1e-80? {}".format(A1_error<TOL and A2_error<TOL), flush=True)
print("  universal drift geometry-independent at 1e-80? {}".format(univ_slope_error<TOL), flush=True)
print("  maximum constraint slope error: {}".format(max_slope_error), flush=True)
print("  direct old-session validation available? {}".format(live), flush=True)
if live:
    print("  maximum direct constraint error: {}".format(max_direct), flush=True)
    print("  maximum affine constraint error: {}".format(max_affine), flush=True)
print("  inherited/verified maximum 70-point closure residual: {}".format(max_closure), flush=True)
print("  sparse pair relations found: {}".format(len(pairs)), flush=True)
print("  checkpoint written: connection_affine_checkpoint.sobj", flush=True)
print("="*78, flush=True)
print("SUCCESS", flush=True)
print("The cell-24 affine certificate was reduced without requiring the old kernel.", flush=True)
print("="*78, flush=True)
